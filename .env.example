# ─────────────────────────────────────────────────────────────────────────────
# Environment configuration for Multi-Agent Procurement Management System
# Copy this file to .env and edit values as needed.
# ─────────────────────────────────────────────────────────────────────────────

# Ollama model to use for local LLM inference
# Options: llama3:8b, phi3, mistral, gemma:2b, etc.
OLLAMA_MODEL=llama3:8b

# Ollama server URL (default: localhost)
OLLAMA_BASE_URL=http://localhost:11434

# LLM temperature (0.0 = fully deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.1

# Maximum retry attempts for failed LLM calls
LLM_MAX_RETRIES=3

# LLM call timeout in seconds
LLM_TIMEOUT_SECONDS=120

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Procurement configuration
DEFAULT_DEPARTMENT=General
PO_PREFIX=PO

# Supplier scoring weights (must sum to 1.0)
SUPPLIER_WEIGHT_RATING=0.40
SUPPLIER_WEIGHT_PRICE=0.35
SUPPLIER_WEIGHT_STOCK=0.15
SUPPLIER_WEIGHT_LEAD_TIME=0.10

# Maximum number of supplier candidates to return
MAX_SUPPLIER_CANDIDATES=3
